# ============================================================================
# system-service 本地配置示例
# 复制为 backend/system-service/.env 后按实际环境修改
# ============================================================================

# ----------------------------------------------------------------------------
# 服务端口
# ----------------------------------------------------------------------------
SERVER_PORT=8081

# ----------------------------------------------------------------------------
# PostgreSQL
# Spring Boot 使用 JDBC URL，不要直接填 Python 那种 postgresql:// DSN
# ----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/handsomew_agent
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ----------------------------------------------------------------------------
# AI Service
# system-service 会把 /agents、/llm-config 等能力接口代理到这里
# ----------------------------------------------------------------------------
AI_SERVICE_BASE_URL=http://127.0.0.1:8000
AI_SERVICE_INTERNAL_TOKEN=

# ----------------------------------------------------------------------------
# MinIO
# 资源上传 / 预览需要
# ----------------------------------------------------------------------------
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=models
MINIO_SECURE=false
MINIO_PRESIGNED_EXPIRE_SECONDS=3600
